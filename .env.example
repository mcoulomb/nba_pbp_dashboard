# NBA PBP Dashboard Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ==============================================================================
# Airflow Configuration
# ==============================================================================
# User ID for Airflow containers (should match your system UID)
AIRFLOW_UID=1000

# Airflow admin credentials for web UI login
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Path to Airflow DAGs folder (relative to docker-compose.yaml)
AIRFLOW_PROJ_DIR=.
AIRFLOW_DAGS_FOLDER=./dags

# ==============================================================================
# Google Cloud Platform (GCP) Configuration
# ==============================================================================
# Path to your GCP service account JSON key file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Example: ./gcp-credentials.json or /path/to/service-account-key.json
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# Your GCP project ID
# Find it in: https://console.cloud.google.com/home/dashboard
GCP_PROJECT_ID=your-project-id-here

# GCS bucket name for storing raw parquet data
# Example: my-company-nba-data-bucket
GCS_BUCKET_NAME=your-gcs-bucket-name

# BigQuery dataset ID (optional, defaults to 'nba_pbp_data')
BIGQUERY_DATASET_ID=nba_pbp_data

# ==============================================================================
# Optional: Advanced Configuration
# ==============================================================================
# Set to 'production' for production deployments
ENVIRONMENT=development

# dbt project directory (if running dbt separately)
DBT_PROJECT_DIR=./nba_pbp_dashboard_dbt

# Additional Airflow configuration (leave empty to use defaults)
# AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
# AIRFLOW__CORE__LOAD_EXAMPLES=False
# AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=300
